<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Lab 9 Advanced Allure Suite" parallel="methods" thread-count="2">
    <parameter name="browser" value="chrome"/>
    <parameter name="env" value="dev"/>
    
    <listeners>
        <listener class-name="utils.ScreenshotOnFailureListener"/>
    </listeners>

    <test name="Allure Login and Cart Tests">
        <classes>
            <class name="bai7_refactor.tests.LoginTest"/>
            <class name="bai2_pom.tests.CartTest"/>
        </classes>
    </test>
</suite>
